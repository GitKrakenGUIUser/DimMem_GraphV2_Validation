 from __future__ import annotations

 import json
+import re

 from typing import Any, Dict, List

@@ -218,15 +219,33 @@ JUDGE_TEMPLATE = r"""

 """

+
+_PROMPT_FIELD_RE = re.compile(r"\{([A-Za-z_][A-Za-z0-9_]*)\}")
+
+
 def render(template: str, **kwargs: Any) -> str:
-
- values = {
-
