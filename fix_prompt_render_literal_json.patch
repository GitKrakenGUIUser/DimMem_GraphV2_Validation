+    """Render only named prompt placeholders and preserve literal JSON braces.
+
+    Python ``str.format`` treats every ``{...}`` block as a formatting field.
+    The prompt templates contain literal JSON examples, so using ``format``
+    raises errors such as ``KeyError: '\\n  "memories"'``.  This renderer
+    replaces only simple named placeholders such as ``{conversation}`` and
+    leaves all other braces untouched.
+    """
+    values = {
+        key: (
+            json.dumps(value, ensure_ascii=False, indent=2)
+            if isinstance(value, (dict, list))
+            else str(value if value is not None else "")
+        )
+        for key, value in kwargs.items()
+    }
+
+    required = set(_PROMPT_FIELD_RE.findall(template))
+    missing = sorted(required.difference(values))
+    if missing:
+        raise KeyError(
+            "Missing prompt render values: "
+            + ", ".join(missing)
+        )
+
+    return _PROMPT_FIELD_RE.sub(
+        lambda match: values[match.group(1)],
+        template,
+    )
