# OpenAI-compatible endpoint. The code appends /chat/completions.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=replace_me
MODEL_NAME=replace_with_your_model

# 0 = submit all selected LongMemEval cases concurrently.
CASE_WORKERS=0
# 0 = run V1 extraction, V2 extraction, and query parse concurrently.
PIPELINE_WORKERS=0
# Inner extraction concurrency per case. 0 = every window concurrently.
# Total extraction requests can approach 2 × CASE_WORKERS × WINDOW_WORKERS.
WINDOW_WORKERS=1
# 0 = BM25, dense, and dimension retrieval routes concurrently per case.
ROUTE_WORKERS=0
# 0 = all active graph tools emitted in one round concurrently.
TOOL_WORKERS=0
# 0 = all four ablation variants concurrently.
VARIANT_WORKERS=0
